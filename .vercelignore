# .vercelignore
# Exclude development, secret, and build artifacts
*.exe
*.dll
node_modules/
.git/
.env
.env.*
.vscode/
.idea/
*.log
coverage/
.dist/
build/
.tmp/
*.sqlite
*.db
*.bak
.DS_Store
# Exclude large binaries and directories
app/
bin/
uploads/
pkg/
static/
public/
# Next.js and Vercel build outputs
.next/
.vercel/
